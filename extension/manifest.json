{
  "manifest_version": 3,
  "name": "Robo-Python Monitor",
  "version": "1.0",
  "author": "Nawa Phansaen",
  "homepage_url": "https://github.com/nawa-dev",
  "description": "Required extension for Robo-Python Simulator to verify testing environment.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1/*",
        "http://localhost/*",
        "https://*.github.io/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
